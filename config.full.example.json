{
  "discord_webhook_url": "https://discord.com/api/webhooks/REPLACE_ME",
  "amazon_from_pattern": "amazon\\.co\\.jp",
  "amazon_subject_pattern": "(配達済み|発送|お届け)",
  "max_messages": 50,
  "poll_interval_seconds": 60,
  "pubsub_subscription": "projects/REPLACE_ME/subscriptions/amazon-notify-sub",
  "pubsub_main_service_name": "amazon-notify-pubsub.service",
  "pubsub_heartbeat_file": "runtime/pubsub-heartbeat.txt",
  "pubsub_heartbeat_interval_seconds": 30,
  "pubsub_heartbeat_max_age_seconds": 300,
  "pubsub_trigger_failure_max_consecutive": 5,
  "pubsub_trigger_failure_base_delay_seconds": 1.0,
  "pubsub_trigger_failure_max_delay_seconds": 60.0,
  "pubsub_stream_reconnect_base_delay_seconds": 1.0,
  "pubsub_stream_reconnect_max_delay_seconds": 60.0,
  "pubsub_stream_reconnect_max_attempts": 0,
  "gmail_api_max_retries": 4,
  "gmail_api_base_delay_seconds": 1.0,
  "gmail_api_max_delay_seconds": 30.0,
  "transient_alert_min_duration_seconds": 600.0,
  "transient_alert_cooldown_seconds": 1800.0,
  "discord_max_retries": 4,
  "discord_base_delay_seconds": 1.0,
  "discord_max_delay_seconds": 30.0,
  "structured_logging": false,
  "state_file": "state.json",
  "transient_state_file": "transient_state.json",
  "events_file": "events.jsonl",
  "runs_file": "runs.jsonl",
  "log_file": "logs/amazon_mail_notifier.log"
}
